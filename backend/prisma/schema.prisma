// نظام إدارة المجالس — نموذج بيانات مرن وديناميكي
// جميع الأدوار والصلاحيات ومسارات العمل تُدار من قاعدة البيانات

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════
// 1. الهيكل التنظيمي الشجري
// ═══════════════════════════════════════════════

model OrganizationUnit {
  id                  String   @id @default(cuid())
  name                String
  code                String   @unique
  parentId            String?
  level               Int      @default(0)           // العمق في الشجرة (يُحسب تلقائياً)
  unitType            String   @default("UNIT")      // ORGANIZATION, AGENCY, DEPARTMENT, DIVISION, SECTION
  isApprovalAuthority Boolean  @default(false)       // نقطة الاعتماد النهائي قبل الأمانة
  managerId           String?                        // مسؤول هذه الوحدة (المعتمِد)
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  parent   OrganizationUnit?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children OrganizationUnit[] @relation("OrgHierarchy")
  manager  User?              @relation("OrgManager", fields: [managerId], references: [id])

  users         User[]
  topics        Topic[]             @relation("RequestingOrg")
  approvalSteps TopicApprovalStep[]

  @@index([parentId])
  @@index([managerId])
}

// ═══════════════════════════════════════════════
// 2. مستويات السرية
// ═══════════════════════════════════════════════

model SecretLevel {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users  User[]
  topics Topic[]
}

// ═══════════════════════════════════════════════
// 3. المستخدمون
// ═══════════════════════════════════════════════

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  displayName    String
  isActive       Boolean  @default(true)
  organizationId String?
  maxClearanceId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization OrganizationUnit? @relation(fields: [organizationId], references: [id])
  maxClearance SecretLevel?      @relation(fields: [maxClearanceId], references: [id])

  roles               UserRole[]
  delegationsFrom     Delegation[]          @relation("DelegationFrom")
  delegationsTo       Delegation[]          @relation("DelegationTo")
  topicsCreated       Topic[]               @relation("TopicCreatedBy")
  examsAssigned       Examination[]         @relation("ExamAssignedBy")
  examsPerformed      Examination[]         @relation("ExamPerformedBy")
  meetingsCreated     Meeting[]             @relation("MeetingCreatedBy")
  minutesSigned       Minutes[]             @relation("MinutesSignedBy")
  memberFeedbacks     MinuteMemberFeedback[]
  decisionsIssued     Decision[]            @relation("DecisionIssuedBy")
  gsReviews           GSReview[]            @relation("GSReviewedBy")
  notifications       Notification[]        @relation("NotificationRecipient")
  auditLogsActual     AuditLog[]            @relation("AuditActorActual")
  auditLogsDisplay    AuditLog[]            @relation("AuditActorDisplay")
  configUpdates       SystemConfig[]        @relation("ConfigUpdatedBy")
  topicStatusActions  TopicStatusLog[]      @relation("StatusLogActor")
  managedOrgUnits     OrganizationUnit[]    @relation("OrgManager")
  approvalStepsDecided TopicApprovalStep[]  @relation("StepApprover")

  @@index([organizationId])
  @@index([email])
}

// ═══════════════════════════════════════════════
// 4. الأدوار الديناميكية
// ═══════════════════════════════════════════════

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  nameAr      String
  nameEn      String   @default("")
  description String?
  isSystem    Boolean  @default(false)       // أدوار أساسية لا تُحذف
  scope       String   @default("GLOBAL")    // GLOBAL, COUNCIL, ORG_UNIT
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  userRoles   UserRole[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  councilId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  council Council? @relation(fields: [councilId], references: [id], onDelete: SetNull)

  @@unique([userId, roleId, councilId])
  @@index([userId])
  @@index([councilId])
}

// ═══════════════════════════════════════════════
// 5. الصلاحيات الديناميكية
// ═══════════════════════════════════════════════

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  nameAr      String
  nameEn      String   @default("")
  module      String                         // TOPIC, MEETING, MINUTES, DECISION, ADMIN, DELEGATION
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ═══════════════════════════════════════════════
// 6. محرك مسارات العمل (Workflow Engine)
// ═══════════════════════════════════════════════

model WorkflowDefinition {
  id         String   @id @default(cuid())
  code       String   @unique              // TOPIC_WORKFLOW, MEETING_WORKFLOW, MINUTES_WORKFLOW
  nameAr     String
  nameEn     String   @default("")
  entityType String                        // Topic, Meeting, Minutes, Decision
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  states      WorkflowState[]
  transitions WorkflowTransition[]
}

model WorkflowState {
  id         String   @id @default(cuid())
  workflowId String
  code       String                        // DRAFT, PENDING_APPROVAL, etc.
  nameAr     String
  nameEn     String   @default("")
  stateType  String   @default("NORMAL")   // INITIAL, NORMAL, APPROVAL, FINAL, CANCELLED
  color      String   @default("default")  // لون البادج: default, blue, green, red, orange, purple, cyan
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)

  workflow        WorkflowDefinition   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromTransitions WorkflowTransition[] @relation("FromState")
  toTransitions   WorkflowTransition[] @relation("ToState")

  @@unique([workflowId, code])
}

model WorkflowTransition {
  id              String  @id @default(cuid())
  workflowId      String
  fromStateId     String
  toStateId       String
  actionCode      String                    // SUBMIT, APPROVE, REJECT, ACCEPT, etc.
  actionNameAr    String                    // إرسال، اعتماد، رفض
  actionNameEn    String  @default("")
  permissionCode  String                    // الصلاحية المطلوبة
  requiresReason  Boolean @default(false)
  requiresComment Boolean @default(false)
  isHierarchical  Boolean @default(false)   // ينتقل للمستوى الأعلى في الهيكل
  autoTransition  Boolean @default(false)   // تحول تلقائي
  buttonColor     String  @default("default") // primary, danger, default, warning
  buttonIcon      String?                   // اسم أيقونة Ant Design
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)

  workflow  WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromState WorkflowState      @relation("FromState", fields: [fromStateId], references: [id])
  toState   WorkflowState      @relation("ToState", fields: [toStateId], references: [id])

  @@unique([workflowId, fromStateId, actionCode])
}

// ═══════════════════════════════════════════════
// 7. سلسلة الاعتماد الهرمي
// ═══════════════════════════════════════════════

model TopicApprovalStep {
  id        String    @id @default(cuid())
  topicId   String
  orgUnitId String
  stepOrder Int                             // ترتيب الخطوة (1, 2, 3, ...)
  approverId String?                        // المعتمِد (مسؤول الوحدة وقت الإنشاء)
  status    String    @default("PENDING")   // PENDING, APPROVED, REJECTED, RETURNED
  decidedAt DateTime?
  reason    String?
  createdAt DateTime  @default(now())

  topic    Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  orgUnit  OrganizationUnit @relation(fields: [orgUnitId], references: [id])
  approver User?            @relation("StepApprover", fields: [approverId], references: [id])

  @@unique([topicId, stepOrder])
  @@index([topicId])
  @@index([approverId, status])
}

// ═══════════════════════════════════════════════
// 8. التفويض
// ═══════════════════════════════════════════════

model Delegation {
  id         String   @id @default(cuid())
  state      String   @default("DELEGATION_DRAFT")
  fromUserId String
  toUserId   String
  scopeType  String   // FULL_ROLE | SPECIFIC_PERMISSION | TOPIC_TYPE
  scopeJson  String   // JSON: { roleCode, permissionCodes[], councilId? }
  validFrom  DateTime
  validUntil DateTime
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fromUser User @relation("DelegationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("DelegationTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId, state])
  @@index([toUserId, state])
}

// ═══════════════════════════════════════════════
// 9. المجلس
// ═══════════════════════════════════════════════

model Council {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics    Topic[]
  userRoles UserRole[]
  meetings  Meeting[]
}

// ═══════════════════════════════════════════════
// 10. الموضوع والمرفقات
// ═══════════════════════════════════════════════

model Topic {
  id                       String    @id @default(cuid())
  refNumber                String    @unique
  title                    String
  body                     String?
  status                   String    @default("DRAFT")
  secrecyLevelId           String?
  councilId                String
  requestingOrgId          String
  createdById              String
  currentVersion           Int       @default(1)
  currentApprovalStepOrder Int?      // الخطوة الحالية في سلسلة الاعتماد الهرمي
  returnType               String?   // FULL_REEXAM | PATH_CORRECTION
  agendaOrder              Int?
  agendaEnteredAt          DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  secrecyLevel  SecretLevel?     @relation(fields: [secrecyLevelId], references: [id])
  council       Council          @relation(fields: [councilId], references: [id])
  requestingOrg OrganizationUnit @relation("RequestingOrg", fields: [requestingOrgId], references: [id])
  createdBy     User             @relation("TopicCreatedBy", fields: [createdById], references: [id])

  attachments   TopicAttachment[]
  statusLogs    TopicStatusLog[]
  gsReviews     GSReview[]
  examinations  Examination[]
  meetingLinks  MeetingTopicLink[]
  decisions     Decision[]
  approvalSteps TopicApprovalStep[]

  @@index([councilId, status])
  @@index([requestingOrgId])
  @@index([status, agendaEnteredAt])
}

model TopicAttachment {
  id           String   @id @default(cuid())
  topicId      String
  fileKey      String
  fileName     String
  mimeType     String?
  sizeBytes    Int?
  uploadedById String
  createdAt    DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model TopicStatusLog {
  id           String   @id @default(cuid())
  topicId      String
  fromStatus   String?
  toStatus     String
  action       String
  actorId      String
  delegationId String?
  reason       String?
  version      Int
  createdAt    DateTime @default(now())

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  actor User  @relation("StatusLogActor", fields: [actorId], references: [id])

  @@index([topicId, createdAt])
}

// ═══════════════════════════════════════════════
// 11. مراجعة الأمين العام
// ═══════════════════════════════════════════════

model GSReview {
  id           String   @id @default(cuid())
  topicId      String
  reviewerId   String
  action       String
  reason       String?
  delegationId String?
  createdAt    DateTime @default(now())

  topic    Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  reviewer User  @relation("GSReviewedBy", fields: [reviewerId], references: [id])

  @@index([topicId])
}

// ═══════════════════════════════════════════════
// 12. الفحص
// ═══════════════════════════════════════════════

model Examination {
  id           String   @id @default(cuid())
  topicId      String
  examinerId   String
  assignedById String
  result       String
  reasons      String?
  version      Int
  createdAt    DateTime @default(now())

  topic      Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  examiner   User  @relation("ExamPerformedBy", fields: [examinerId], references: [id])
  assignedBy User  @relation("ExamAssignedBy", fields: [assignedById], references: [id])

  @@index([topicId])
}

// ═══════════════════════════════════════════════
// 13. الاجتماع والأجندة
// ═══════════════════════════════════════════════

model Meeting {
  id          String    @id @default(cuid())
  refNumber   String    @unique
  councilId   String
  status      String    @default("MEETING_DRAFT_SEC")
  title       String?
  scheduledAt DateTime?
  heldAt      DateTime?
  location    String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  council   Council @relation(fields: [councilId], references: [id])
  createdBy User    @relation("MeetingCreatedBy", fields: [createdById], references: [id])

  topicLinks MeetingTopicLink[]
  minutes    Minutes[]

  @@index([councilId, status])
}

model MeetingTopicLink {
  id         String @id @default(cuid())
  meetingId  String
  topicId    String
  orderIndex Int    @default(0)
  slotStatus String @default("SCHEDULED")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  topic   Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([meetingId, topicId])
  @@index([meetingId])
}

// ═══════════════════════════════════════════════
// 14. المحضر ومرئيات الأعضاء
// ═══════════════════════════════════════════════

model Minutes {
  id               String    @id @default(cuid())
  meetingId        String    @unique
  status           String    @default("MIN_DRAFT")
  body             String?
  feedbackDeadline DateTime?
  signedAt         DateTime?
  signedById       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  signedBy  User?    @relation("MinutesSignedBy", fields: [signedById], references: [id])

  feedbacks MinuteMemberFeedback[]
  decisions Decision[]

  @@index([meetingId])
}

model MinuteMemberFeedback {
  id        String   @id @default(cuid())
  minutesId String
  memberId  String
  approved  Boolean  @default(true)
  comment   String?
  createdAt DateTime @default(now())

  minutes Minutes @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  member  User    @relation(fields: [memberId], references: [id])

  @@index([minutesId])
}

// ═══════════════════════════════════════════════
// 15. القرار
// ═══════════════════════════════════════════════

model Decision {
  id         String    @id @default(cuid())
  refNumber  String    @unique
  topicId    String
  minutesId  String?
  status     String    @default("DEC_DRAFT")
  summary    String?
  issuedAt   DateTime?
  issuedById String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  topic    Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  minutes  Minutes? @relation(fields: [minutesId], references: [id], onDelete: SetNull)
  issuedBy User?    @relation("DecisionIssuedBy", fields: [issuedById], references: [id])

  notifications Notification[]

  @@index([topicId, status])
}

// ═══════════════════════════════════════════════
// 16. التبليغات والإشعارات
// ═══════════════════════════════════════════════

model Notification {
  id             String    @id @default(cuid())
  type           String
  status         String    @default("NOTIF_PENDING")
  decisionId     String?
  recipientId    String
  recipientOrgId String?
  title          String
  body           String?
  readAt         DateTime?
  retryCount     Int       @default(0)
  nextRetryAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  decision  Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  recipient User      @relation("NotificationRecipient", fields: [recipientId], references: [id])

  attempts NotificationDeliveryAttempt[]

  @@index([recipientId, status])
}

model NotificationDeliveryAttempt {
  id             String   @id @default(cuid())
  notificationId String
  attemptNumber  Int
  result         String
  errorDetail    String?
  attemptedAt    DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
}

// ═══════════════════════════════════════════════
// 17. سجل التدقيق
// ═══════════════════════════════════════════════

model AuditLog {
  id                String   @id @default(cuid())
  entityType        String
  entityId          String
  action            String
  actorActualId     String
  actorDisplayId    String
  visibilityProfile String   @default("FULL_AUDIT")
  delegationId      String?
  reason            String?
  beforeJson        String?
  afterJson         String?
  ipAddress         String?
  createdAt         DateTime @default(now())

  actorActual  User @relation("AuditActorActual", fields: [actorActualId], references: [id])
  actorDisplay User @relation("AuditActorDisplay", fields: [actorDisplayId], references: [id])

  @@index([entityType, entityId])
  @@index([actorActualId, createdAt])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════
// 18. معلمات التهيئة
// ═══════════════════════════════════════════════

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  valueType   String   @default("STRING")
  description String?
  updatedAt   DateTime @updatedAt
  updatedById String?

  updatedBy User? @relation("ConfigUpdatedBy", fields: [updatedById], references: [id])
}
